    function WindowObj:CreateTab(name, iconId)
        local tabBtn = new("TextButton", {
            Size = UDim2.new(1, -14, 0, isMobile and 36 or 32),
            BackgroundColor3 = theme.Elevated,
            BackgroundTransparency = 1,
