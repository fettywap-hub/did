        Size = UDim2.new(0, 14, 0, 14), BackgroundTransparency = 1,
        ZIndex = 20, Parent = Window,
    })
    for i = 0, 2 do
        new("Frame", {
            AnchorPoint = Vector2.new(1, 1), Position = UDim2.new(1, -i*4, 1, 0),
            Size = UDim2.new(0, 2, 0, (i+1)*4),
            BackgroundColor3 = theme.SubText, BackgroundTransparency = 0.5,
            BorderSizePixel = 0, Parent = Grip,
        })
    end
    do
        local resizing, startPos, startSize
        Grip.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing, startPos, startSize = true, input.Position, Window.Size
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local d = input.Position - startPos
                Window.Size = UDim2.new(0, math.max(440, startSize.X.Offset + d.X),
                                        0, math.max(280, startSize.Y.Offset + d.Y))
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then resizing = false end
        end)
    end

    if opts.ToggleKey then
        UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.KeyCode == opts.ToggleKey then
                Window.Visible = not Window.Visible
                setBlur(Window.Visible, 8)
            end
        end)
    end

    local WindowObj = {
        _tabs = {}, _theme = theme, _content = Content,
        _configFolder = opts.ConfigFolder or (opts.Name or "EniLib"):gsub("%s+", "_"),
        _autoSave = opts.AutoSave or false,
        _animSpeed = animSpeed,
        _repainters = repainters,
    }

    -- THE KEY FIX: UpdateTheme now mutates `theme` AND fires every registered repainter
    function WindowObj:UpdateTheme(newTheme)
        local nt = type(newTheme) == "table" and newTheme or Themes[newTheme]
        if not nt then return end
        for k, v in pairs(nt) do theme[k] = v end
        -- repaint the window chrome
        tw(Window, 0.3, {BackgroundColor3 = theme.Background})
        tw(TitleBar, 0.3, {BackgroundColor3 = theme.Surface})
        tw(Sidebar, 0.3, {BackgroundColor3 = theme.Surface})
        tw(TitleText, 0.3, {TextColor3 = theme.Text})
        if SubText then tw(SubText, 0.3, {TextColor3 = theme.SubText}) end
        tw(titleDivider, 0.3, {BackgroundColor3 = theme.Border})
        tw(sideDivider, 0.3, {BackgroundColor3 = theme.Border})
        tw(Indicator, 0.3, {BackgroundColor3 = theme.Accent})
        if windowGlass and windowGlass.tint then
            tw(windowGlass.tint, 0.3, {BackgroundColor3 = theme.Tint})
        end
        -- fire every element repainter
        for _, fn in ipairs(repainters) do
            pcall(fn, theme)
        end
    end

    -- splash → window
    if Splash then
        task.delay(SPEED(1.5), function()
            tw(Splash, SPEED(0.3), {BackgroundTransparency = 1})
            for _, c in ipairs(Splash:GetDescendants()) do
                if c:IsA("TextLabel") then tw(c, SPEED(0.3), {TextTransparency = 1}) end
                if c:IsA("Frame") then tw(c, SPEED(0.3), {BackgroundTransparency = 1}) end
            end
            task.wait(SPEED(0.3))
            Splash:Destroy()
            Window.Visible = true
            Window.Size = UDim2.new(0, 0, 0, 0)
            Window.Position = UDim2.new(0.5, 0, 0.5, 0)
            tw(Window, SPEED(0.4), {
                Size = UDim2.new(0, 600, 0, 420),
                Position = UDim2.new(0.5, -300, 0.5, -210),
            }, Enum.EasingStyle.Back)
        end)
    else
        setBlur(true, 8)
    end

    --==========================================================
    -- TABS / ELEMENTS
    --==========================================================
    function WindowObj:CreateTab(name, iconId)
        local tabBtn = new("TextButton", {
            Size = UDim2.new(1, -14, 0, 32),
            BackgroundColor3 = theme.Elevated, BackgroundTransparency = 1,
            BorderSizePixel = 0, Text = "", AutoButtonColor = false,
            ZIndex = 7, Parent = SidebarList,
        })
        corner(tabBtn, 8)
        local tabLabel = new("TextLabel", {
            Position = UDim2.new(0, iconId and 30 or 12, 0, 0),
            Size = UDim2.new(1, iconId and -36 or -16, 1, 0),
            BackgroundTransparency = 1, Text = name,
            TextColor3 = theme.SubText, Font = Enum.Font.Gotham, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 8, Parent = tabBtn,
        })
        local tabIcon
        if iconId then
            tabIcon = new("ImageLabel", {
                Position = UDim2.new(0, 8, 0.5, -8), Size = UDim2.new(0, 16, 0, 16),
                BackgroundTransparency = 1, Image = "rbxassetid://" .. tostring(iconId),
                ImageColor3 = theme.SubText, ZIndex = 8, Parent = tabBtn,
            })
        end

        local TabFrame = new("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
            BorderSizePixel = 0, ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.AccentDark,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false, ZIndex = 4, Parent = Content,
        }, {new("UIListLayout", {Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder})})
        padding(TabFrame, 16, 16, 16, 16)

        local isSelected = false
        local function select()
            for _, t in ipairs(WindowObj._tabs) do
                if t.frame.Visible and t.frame ~= TabFrame then
                    tw(t.frame, SPEED(0.18), {Position = UDim2.new(-0.05, 0, 0, 0)})
                    task.delay(SPEED(0.18), function() t.frame.Visible = false end)
                end
                tw(t.label, SPEED(0.15), {TextColor3 = theme.SubText})
                if t.icon then tw(t.icon, SPEED(0.15), {ImageColor3 = theme.SubText}) end
                tw(t.btn, SPEED(0.15), {BackgroundTransparency = 1})
                t.selected = false
            end
            TabFrame.Position = UDim2.new(0.05, 0, 0, 0)
            TabFrame.Visible = true
            tw(TabFrame, SPEED(0.25), {Position = UDim2.new(0, 0, 0, 0)})
            tw(tabBtn, SPEED(0.18), {BackgroundTransparency = 0.4, BackgroundColor3 = theme.Elevated})
            tw(tabLabel, SPEED(0.18), {TextColor3 = theme.Text})
            if tabIcon then tw(tabIcon, SPEED(0.18), {ImageColor3 = theme.Accent}) end
            local absPos = tabBtn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y
            tw(Indicator, SPEED(0.3), {
                Position = UDim2.new(0, 6, 0, absPos + 3),
                BackgroundTransparency = 0,
            }, Enum.EasingStyle.Back)
            isSelected = true
        end

        tabBtn.MouseButton1Click:Connect(select)
        tabBtn.MouseEnter:Connect(function()
            if not isSelected then tw(tabLabel, SPEED(0.12), {TextColor3 = theme.Text}) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if not isSelected then tw(tabLabel, SPEED(0.12), {TextColor3 = theme.SubText}) end
        end)

        local tabRecord = {btn = tabBtn, frame = TabFrame, label = tabLabel, icon = tabIcon, selected = false}
        table.insert(WindowObj._tabs, tabRecord)
        if #WindowObj._tabs == 1 then task.defer(select) end

        -- register tab chrome repainter
        table.insert(repainters, function(t)
            tw(tabBtn, 0.3, {BackgroundColor3 = t.Elevated})
            tw(tabLabel, 0.3, {TextColor3 = tabRecord.selected and t.Text or t.SubText})
            if tabIcon then tw(tabIcon, 0.3, {ImageColor3 = tabRecord.selected and t.Accent or t.SubText}) end
            tw(TabFrame, 0.3, {ScrollBarImageColor3 = t.AccentDark})
        end)

        local Tab = {}
        local function autosave()
            if WindowObj._autoSave then
                task.spawn(function() EniLib:SaveConfig(WindowObj, "auto") end)
            end
        end

        -- helper to spawn a glass-styled row
        local function mkRow(h)
            local row = new("Frame", {
                Size = UDim2.new(1, 0, 0, h or 38),
                BackgroundColor3 = theme.Surface, BackgroundTransparency = 0.25,
                BorderSizePixel = 0, ZIndex = 5, Parent = TabFrame,
            })
            corner(row, 10)
            local rowStroke = stroke(row, theme.Border, 1, 0.4)
            -- inner gloss
            local g = new("Frame", {
                Size = UDim2.new(1, 0, 0.5, 0), BackgroundColor3 = Color3.fromRGB(255,255,255),
                BackgroundTransparency = 0.93, BorderSizePixel = 0,
                ZIndex = 5, Parent = row,
            })
            corner(g, 10)
            new("UIGradient", {
                Color = ColorSequence.new(Color3.fromRGB(255,255,255)),
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 0.85),
                    NumberSequenceKeypoint.new(1, 1),
                }, Rotation = 90, Parent = g,
            })
            table.insert(repainters, function(t)
                tw(row, 0.3, {BackgroundColor3 = t.Surface})
                tw(rowStroke, 0.3, {Color = t.Border})
            end)
            return row, rowStroke
        end

