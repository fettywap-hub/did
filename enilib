function EniLib:Notify(opts)
    opts = opts or {}
    local theme = self._theme or Themes.Rose
    local accentColor = ({
        info = theme.Accent, success = theme.Success,
        warning = theme.Warning, error = theme.Danger,
    })[opts.Type or "info"]

    local card = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = theme.Surface,
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = NotifContainer,
    })
    corner(card, 12)
    stroke(card, theme.Border, 1, 0.4)
    attachShimmer(card, {Duration = 1.4, Gap = 7, Peak = 0.18, Band = 0.12, Rotation = 18})

    local accent = new("Frame", {
        Position = UDim2.new(0, 10, 0, 10),
        Size = UDim2.new(0, 3, 1, -20),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = card,
    })
    corner(accent, 2)

    local title = new("TextLabel", {
        Position = UDim2.new(0, 22, 0, 12),
        Size = UDim2.new(1, -32, 0, 18),
        BackgroundTransparency = 1,
        Text = opts.Title or "Notification",
        TextColor3 = theme.Text,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        Parent = card,
    })
    local body = new("TextLabel", {
        Position = UDim2.new(0, 22, 0, 32),
        Size = UDim2.new(1, -32, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Text = opts.Content or "",
        TextColor3 = theme.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextTransparency = 1,
        Parent = card,
    })
    padding(card, 0, 0, 14, 0)

    card.Position = UDim2.new(1, 100, 0, 0)
    tw(card, 0.35, {Position = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back)
    tw(title, 0.3, {TextTransparency = 0})
    tw(body,  0.3, {TextTransparency = 0})

    task.spawn(function()
        task.wait(opts.Duration or 4)
        tw(card,  0.3, {BackgroundTransparency = 1})
        tw(title, 0.3, {TextTransparency = 1})
        tw(body,  0.3, {TextTransparency = 1})
        tw(accent,0.3, {BackgroundTransparency = 1})
        task.wait(0.35)
        card:Destroy()
    end)
end

------------------------------------------------------------------ Window
function EniLib:CreateWindow(opts)
    opts = opts or {}
    local theme = type(opts.Theme) == "table" and opts.Theme or Themes[opts.Theme or "Rose"]
    self._theme = theme
    local animSpeed = opts.AnimationSpeed or 1
    local SPEED = function(t) return t / animSpeed end

    local platform = detectPlatform()
    local isMobile = (platform == "mobile")

    -- Base sizes depending on platform
    local baseW = opts.Size and opts.Size.X or (isMobile and 380 or 620)
    local baseH = opts.Size and opts.Size.Y or (isMobile and 460 or 440)
    local minW  = isMobile and 320 or 460
    local minH  = isMobile and 320 or 300
    local sidebarW = isMobile and 130 or 160
    local titleH   = isMobile and 48  or 46
    local touchPad = isMobile and 4   or 0

    local repainters = {}

    ----------------------------- Splash
    local Splash
    if opts.ShowSplash ~= false then
        Splash = new("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(340, 130),
            BackgroundColor3 = theme.Surface,
            BackgroundTransparency = 0.05,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 100,
            Parent = ScreenGui,
        })
        corner(Splash, 16); stroke(Splash, theme.Border, 1, 0.3)
        attachShimmer(Splash, {Duration = 2.0, Gap = 1.6, Peak = 0.22, Band = 0.15, Rotation = 18})
        local sT = new("TextLabel", {
            Position = UDim2.new(0, 0, 0, 36),
            Size = UDim2.new(1, 0, 0, 32),
            BackgroundTransparency = 1,
            Text = opts.Name or "EniLib",
            TextColor3 = theme.Text,
            Font = Enum.Font.GothamBold, TextSize = 22,
            TextTransparency = 1, ZIndex = 101, Parent = Splash,
        })
        local sS = new("TextLabel", {
            Position = UDim2.new(0, 0, 0, 70),
            Size = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1,
            Text = opts.SubTitle or "loading…",
            TextColor3 = theme.SubText,
            Font = Enum.Font.Gotham, TextSize = 12,
            TextTransparency = 1, ZIndex = 101, Parent = Splash,
        })
        local barTrack = new("Frame", {
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new(0.5, 0, 1, -18),
            Size = UDim2.fromOffset(220, 2),
            BackgroundColor3 = theme.Elevated, BackgroundTransparency = 0.3,
            BorderSizePixel = 0, ZIndex = 101, Parent = Splash,
        })
        corner(barTrack, 1)
        local bar = new("Frame", {
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new(0.5, 0, 1, -18),
            Size = UDim2.fromOffset(0, 2),
            BackgroundColor3 = theme.Accent,
            BorderSizePixel = 0, ZIndex = 102, Parent = Splash,
        })
        corner(bar, 1)
        attachShimmer(bar, {Duration = 0.7, Gap = 0.2, Peak = 0.5, Band = 0.2})
        tw(sT,  SPEED(0.4), {TextTransparency = 0})
        tw(sS,  SPEED(0.5), {TextTransparency = 0})
        tw(bar, SPEED(0.9), {Size = UDim2.fromOffset(220, 2)})
        setBlur(true, 12)
    end

    ----------------------------- Window root
    local Window = new("Frame", {
        Size = UDim2.fromOffset(baseW, baseH),
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = theme.Background,
        BackgroundTransparency = 0.04,
        BorderSizePixel = 0,
        Visible = (opts.ShowSplash == false),
        Parent = ScreenGui,
    })
    corner(Window, 14)
    local winStroke = stroke(Window, theme.Border, 1, 0.25)
    local winShadow = dropShadow(Window, 0.55, 28)

    -- Root UIScale: makes everything inside Window scale together.
    local rootScale = new("UIScale", {Scale = 1, Parent = Window})

    -- A subtle interior gradient for depth
    local interior = new("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = theme.Tint,
        BackgroundTransparency = 0.6,
        BorderSizePixel = 0,
        ZIndex = 1,
        Parent = Window,
    })
    corner(interior, 14)
    new("UIGradient", {
        Color = ColorSequence.new(Color3.fromRGB(255, 255, 255)),
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, 0.85),
            NumberSequenceKeypoint.new(1, 1),
        },
        Rotation = 135,
        Parent = interior,
    })

    -- Responsive: react to viewport changes
    local function applyResponsive()
        local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
        local minDim = math.min(vp.X, vp.Y)
        -- Scale tuned so phones get ~0.85, tablets ~0.95, desktops ~1.0+
        local s
        if isMobile then
            s = math.clamp(minDim / 720, 0.78, 1.0)
        else
            s = math.clamp(minDim / 900, 0.82, 1.15)
        end
        rootScale.Scale = s
        -- Clamp window to viewport
