------------------------------------------------------------------ Helpers
local function new(class, props, children)
    local i = Instance.new(class)
    if props then for k, v in pairs(props) do i[k] = v end end
    if children then for _, c in ipairs(children) do c.Parent = i end end
    return i
end
local function corner(parent, r)
    return new("UICorner", {CornerRadius = UDim.new(0, r or 8), Parent = parent})
end
local function stroke(parent, color, thick, trans)
    return new("UIStroke", {
        Color = color, Thickness = thick or 1, Transparency = trans or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = parent,
    })
end
local function padding(parent, t, r, b, l)
    return new("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingRight  = UDim.new(0, r or 0),
        PaddingBottom = UDim.new(0, b or 0),
        PaddingLeft   = UDim.new(0, l or 0),
        Parent = parent,
    })
end
local function tw(obj, dur, props, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(
        dur, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out
    ), props)
    t:Play()
    return t
end

------------------------------------------------------------------ Gradient-based shimmer (no extra frames)
-- Attaches a UIGradient to `host` and animates its Offset.X.
-- The gradient has a narrow translucent band in its transparency curve,
-- so as Offset moves, a highlight sweeps across whatever the parent paints.
local function attachShimmer(host, opts)
    opts = opts or {}
    local dur     = opts.Duration or 2.6
    local gap     = opts.Gap      or 3.0
    local peak    = opts.Peak     or 0.78    -- 0 = invisible, 1 = fully opaque white band
    local rotation= opts.Rotation or 0
    local band    = opts.Band     or 0.18    -- width of the bright band (0..1)

    local g = new("UIGradient", {
        Color = ColorSequence.new(Color3.fromRGB(255, 255, 255)),
        Rotation = rotation,
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0,                1),
            NumberSequenceKeypoint.new(math.max(0.001, 0.5 - band), 1),
            NumberSequenceKeypoint.new(0.5,              1 - peak),
            NumberSequenceKeypoint.new(math.min(0.999, 0.5 + band), 1),
            NumberSequenceKeypoint.new(1,                1),
        },
        Offset = Vector2.new(-1, 0),
        Parent = host,
    })

    local alive = true
    task.spawn(function()
        while alive and g.Parent do
            g.Offset = Vector2.new(-1, 0)
            local t = TweenService:Create(g, TweenInfo.new(dur, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Offset = Vector2.new(1, 0),
            })
            t:Play()
            t.Completed:Wait()
            if not (alive and g.Parent) then break end
            task.wait(gap)
        end
    end)
    g.AncestryChanged:Connect(function(_, p) if not p then alive = false end end)
    return g
end

------------------------------------------------------------------ Drop shadow
local SHADOW_ASSET = "rbxassetid://6014261993" -- soft round shadow (built-in style)
local function dropShadow(target, opacity, spread)
    opacity = opacity or 0.55
    spread  = spread or 24
    local s = new("ImageLabel", {
        Name = "Shadow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1,
        Image = SHADOW_ASSET,
        ImageColor3 = Color3.new(0, 0, 0),
        ImageTransparency = 1 - opacity,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        Position = UDim2.new(0.5, 0, 0.5, 2),
        Size = UDim2.new(1, spread * 2, 1, spread * 2),
        ZIndex = (target.ZIndex or 1) - 1,
        Parent = target.Parent,
    })
    target:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() end) -- size already scales
    return s
end

------------------------------------------------------------------ Icon glyphs (frame-based, vector-clean)
local function mkIcon(parent, kind, color, size, thickness)
    size = size or 12
    thickness = thickness or 1.6
    local icon = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        Size = UDim2.fromOffset(size, size),
        BackgroundTransparency = 1,
        ZIndex = parent.ZIndex + 1,
        Parent = parent,
    })
    local parts = {}
    local function bar(rot, w, h, ax, ay, px, py)
        local f = new("Frame", {
            AnchorPoint = Vector2.new(ax or 0.5, ay or 0.5),
            Position    = UDim2.fromScale(px or 0.5, py or 0.5),
            Size        = UDim2.fromOffset(w, h),
            BackgroundColor3 = color,
            BorderSizePixel  = 0,
            Rotation = rot or 0,
            ZIndex = icon.ZIndex,
            Parent = icon,
        })
        corner(f, math.floor(h/2))
        table.insert(parts, f)
        return f
    end
    if kind == "close" then
        bar(45,  size, thickness)
        bar(-45, size, thickness)
    elseif kind == "minus" then
        bar(0, size, thickness)
    elseif kind == "chevronDown" then
        bar( 45, size*0.6, thickness, 0, 0.5, 0.30, 0.45)
        bar(-45, size*0.6, thickness, 1, 0.5, 0.70, 0.45)
    elseif kind == "chevronRight" then
        bar( 45, size*0.6, thickness, 0.5, 0, 0.45, 0.30)
        bar(-45, size*0.6, thickness, 0.5, 1, 0.45, 0.70)
    elseif kind == "search" then
        local ring = new("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.42, 0.42),
            Size = UDim2.fromOffset(size*0.65, size*0.65),
            BackgroundTransparency = 1,
            ZIndex = icon.ZIndex, Parent = icon,
        })
        stroke(ring, color, thickness, 0)
        corner(ring, 999)
        bar(45, size*0.4, thickness, 0, 0.5, 0.7, 0.78)
    end
    return icon, parts
end

------------------------------------------------------------------ Ripple
local function ripple(button, x, y)
    if not button:IsDescendantOf(game) then return end
    local r = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromOffset(x - button.AbsolutePosition.X, y - button.AbsolutePosition.Y),
        Size = UDim2.fromOffset(0, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.65,
        BorderSizePixel = 0,
        ZIndex = button.ZIndex + 5,
        Parent = button,
    })
    corner(r, 999)
    local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.4
    tw(r, 0.55, {Size = UDim2.fromOffset(size, size), BackgroundTransparency = 1})
    Debris:AddItem(r, 0.6)
end

------------------------------------------------------------------ Draggable
local function draggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging, dragStart, startPos = true, input.Position, frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                      or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

