        function Tab:CreateToggle(o)
            local state = o.CurrentValue or false
            local row = mkRow(rowH)
            local btn = new("TextButton", {
                Size = UDim2.fromScale(1, 1),
                BackgroundTransparency = 1,
                Text = "", AutoButtonColor = false,
                ZIndex = 7, Parent = row,
            })
            local label = new("TextLabel", {
                Position = UDim2.new(0, 14, 0, 0),
                Size = UDim2.new(1, -64, 1, 0),
                BackgroundTransparency = 1,
                Text = o.Name or "Toggle",
                TextColor3 = theme.Text,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 8, Parent = btn,
            })
            local track = new("Frame", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0.5, 0),
                Size = UDim2.fromOffset(38, 20),
                BackgroundColor3 = theme.Elevated,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 8, Parent = btn,
            })
            corner(track, 10); stroke(track, theme.Border, 1, 0.5)
            local trackShimmer = attachShimmer(track, {Duration = 1.4, Gap = 1.6, Peak = 0.35, Band = 0.16})
            trackShimmer.Enabled = false

            local knob = new("Frame", {
                Position = UDim2.new(0, 3, 0.5, -8),
                Size = UDim2.fromOffset(16, 16),
                BackgroundColor3 = theme.SubText,
                BorderSizePixel = 0,
                ZIndex = 10, Parent = track,
            })
            corner(knob, 8)

            local function render(anim)
                if state then
                    tw(track, SPEED(0.2), {BackgroundColor3 = theme.Accent})
                    tw(knob, SPEED(0.25), {
                        Position = UDim2.new(0, 19, 0.5, -8),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    }, Enum.EasingStyle.Back)
                    trackShimmer.Enabled = true
                else
                    tw(track, SPEED(0.2), {BackgroundColor3 = theme.Elevated})
                    tw(knob, SPEED(0.25), {
                        Position = UDim2.new(0, 3, 0.5, -8),
                        BackgroundColor3 = theme.SubText,
                    }, Enum.EasingStyle.Back)
                    trackShimmer.Enabled = false
                end
            end
            render(false)

            local handle = {CurrentValue = state}
            function handle:Set(v)
                state = v and true or false
                self.CurrentValue = state
                render(true)
                if o.Callback then pcall(o.Callback, state) end
                autosave()
            end
            btn.MouseButton1Click:Connect(function() handle:Set(not state) end)
            if o.Flag then EniLib.Flags[o.Flag] = handle end
            table.insert(repainters, function(t)
                tw(label, 0.3, {TextColor3 = t.Text})
                if state then tw(track, 0.3, {BackgroundColor3 = t.Accent})
                else
                    tw(track, 0.3, {BackgroundColor3 = t.Elevated})
                    tw(knob, 0.3, {BackgroundColor3 = t.SubText})
                end
            end)
            return handle
        end

        function Tab:CreateSlider(o)
            local range = o.Range or {0, 100}
            local val   = o.CurrentValue or range[1]
            local inc   = o.Increment or 1
            local suffix = o.Suffix or ""
            local row = mkRow(isMobile and 64 or 58)
            local label = new("TextLabel", {
                Position = UDim2.new(0, 14, 0, 8),
                Size = UDim2.new(1, -28, 0, 18),
                BackgroundTransparency = 1,
                Text = o.Name or "Slider",
                TextColor3 = theme.Text,
                Font = Enum.Font.Gotham, TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 7, Parent = row,
            })
            local valLabel = new("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -14, 0, 8),
                Size = UDim2.fromOffset(90, 18),
                BackgroundTransparency = 1,
                Text = tostring(val) .. suffix,
                TextColor3 = theme.Accent,
                Font = Enum.Font.GothamBold, TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 7, Parent = row,
            })
            local track = new("Frame", {
                Position = UDim2.new(0, 14, 1, isMobile and -20 or -18),
                Size = UDim2.new(1, -28, 0, isMobile and 8 or 6),
                BackgroundColor3 = theme.Elevated,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 7, Parent = row,
            })
            corner(track, 3)
            local fill = new("Frame", {
                Size = UDim2.fromScale(0, 1),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 8, Parent = track,
            })
            corner(fill, 3)
            attachShimmer(fill, {Duration = 1.8, Gap = 1.2, Peak = 0.30, Band = 0.18})
            local knob = new("Frame", {
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.fromScale(0, 0.5),
                Size = UDim2.fromOffset(isMobile and 18 or 14, isMobile and 18 or 14),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                ZIndex = 9, Parent = track,
            })
            corner(knob, 999); local knobStroke = stroke(knob, theme.Accent, 2)

            local pct0 = (val - range[1]) / (range[2] - range[1])
            fill.Size = UDim2.fromScale(pct0, 1)
            knob.Position = UDim2.new(pct0, 0, 0.5, 0)

            local handle = {CurrentValue = val}
            local function setFromX(x)
                local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local raw = range[1] + (range[2] - range[1]) * rel
                local snap = math.floor((raw / inc) + 0.5) * inc
                snap = math.clamp(snap, range[1], range[2])
                handle.CurrentValue = snap
                valLabel.Text = tostring(snap) .. suffix
                local p = (snap - range[1]) / (range[2] - range[1])
                tw(fill, SPEED(0.08), {Size = UDim2.fromScale(p, 1)})
                tw(knob, SPEED(0.08), {Position = UDim2.new(p, 0, 0.5, 0)})
                if o.Callback then pcall(o.Callback, snap) end
            end
            local dragging
            track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragging = true; setFromX(i.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    setFromX(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    if dragging then autosave() end
                    dragging = false
                end
            end)
            function handle:Set(v)
                v = math.clamp(v, range[1], range[2])
                self.CurrentValue = v
                valLabel.Text = tostring(v) .. suffix
                local p = (v - range[1]) / (range[2] - range[1])
                tw(fill, SPEED(0.15), {Size = UDim2.fromScale(p, 1)})
                tw(knob, SPEED(0.15), {Position = UDim2.new(p, 0, 0.5, 0)})
                if o.Callback then pcall(o.Callback, v) end
                autosave()
            end
            if o.Flag then EniLib.Flags[o.Flag] = handle end
            table.insert(repainters, function(t)
                tw(label,    0.3, {TextColor3 = t.Text})
                tw(valLabel, 0.3, {TextColor3 = t.Accent})
                tw(track,    0.3, {BackgroundColor3 = t.Elevated})
                tw(fill,     0.3, {BackgroundColor3 = t.Accent})
                tw(knobStroke, 0.3, {Color = t.Accent})
            end)
            return handle
        end

