--==============================================================
-- HELPERS
--==============================================================
local function new(class, props, children)
    local i = Instance.new(class)
    for k, v in pairs(props or {}) do i[k] = v end
    for _, c in ipairs(children or {}) do c.Parent = i end
    return i
end
local function corner(parent, r) return new("UICorner", {CornerRadius = UDim.new(0, r or 8), Parent = parent}) end
local function stroke(parent, color, thick, trans)
    return new("UIStroke", {Color = color, Thickness = thick or 1, Transparency = trans or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Parent = parent})
end
local function padding(parent, t, r, b, l)
    return new("UIPadding", {PaddingTop = UDim.new(0, t or 0), PaddingRight = UDim.new(0, r or 0),
        PaddingBottom = UDim.new(0, b or 0), PaddingLeft = UDim.new(0, l or 0), Parent = parent})
end
local function tw(obj, dur, props, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(dur, style or Enum.EasingStyle.Quart,
        dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

-- LIQUID GLASS LAYER — drops behind any frame to give frosted look
local function glassLayer(parent, theme, blurStrength)
    blurStrength = blurStrength or 0.7
    -- base tinted layer
    local tint = new("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = theme.Tint,
        BackgroundTransparency = 0.15,
        BorderSizePixel = 0,
        ZIndex = parent.ZIndex,
        Parent = parent,
    })
    corner(tint, 12)
    -- glossy top highlight
    local gloss = new("Frame", {
        Size = UDim2.new(1, 0, 0.5, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.92,
        BorderSizePixel = 0,
        ZIndex = parent.ZIndex + 1,
        Parent = parent,
    })
    corner(gloss, 12)
    new("UIGradient", {
        Color = ColorSequence.new(Color3.fromRGB(255,255,255)),
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, 0.7),
            NumberSequenceKeypoint.new(1, 1),
        },
        Rotation = 90,
        Parent = gloss,
    })
    -- inner edge highlight
    local edge = new("Frame", {
        Size = UDim2.new(1, -2, 1, -2),
        Position = UDim2.new(0, 1, 0, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = parent.ZIndex + 2,
        Parent = parent,
    })
    corner(edge, 11)
    stroke(edge, Color3.fromRGB(255, 255, 255), 1, 0.85)
    return {tint = tint, gloss = gloss, edge = edge}
end

local function ripple(button, x, y)
    local r = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromOffset(x - button.AbsolutePosition.X, y - button.AbsolutePosition.Y),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.6,
        BorderSizePixel = 0,
        ZIndex = button.ZIndex + 5,
        Parent = button,
    })
    corner(r, 999)
    local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    tw(r, 0.6, {Size = UDim2.fromOffset(size, size), BackgroundTransparency = 1})
    Debris:AddItem(r, 0.65)
end

local function pulse(parent, color)
    local g = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ZIndex = parent.ZIndex + 1, Parent = parent,
    })
    corner(g, 999)
    local s = stroke(g, color, 2, 0)
    tw(g, 0.5, {Size = UDim2.new(1, 18, 1, 18)})
    tw(s, 0.5, {Transparency = 1})
    Debris:AddItem(g, 0.55)
end

local function draggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging, dragStart, startPos = true, input.Position, frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                      or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                       startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
end

local function getParent()
    if gethui then return gethui() end
    local ok = pcall(function() return CoreGui:GetChildren() end)
    if ok then return CoreGui end
    return LP:WaitForChild("PlayerGui")
end

-- BLUR EFFECT (real Lighting blur behind UI when enabled)
local Lighting = game:GetService("Lighting")
local backgroundBlur = nil
local function setBlur(on, intensity)
    if on then
        if not backgroundBlur then
            backgroundBlur = Instance.new("BlurEffect")
            backgroundBlur.Name = "EniLibBlur"
            backgroundBlur.Size = 0
            backgroundBlur.Parent = Lighting
        end
        tw(backgroundBlur, 0.3, {Size = intensity or 8})
    else
        if backgroundBlur then
            tw(backgroundBlur, 0.3, {Size = 0})
        end
    end
end

--==============================================================
-- CONFIG SAVING
--==============================================================
local hasFiles = (writefile and readfile and isfile and isfolder and makefolder) and true or false

local function ensureFolder(path)
    if not hasFiles then return false end
    if not isfolder(path) then makefolder(path) end
    return true
end

local function serializeValue(v)
    if typeof(v) == "Color3" then
        return {_t = "Color3", r = math.floor(v.R*255), g = math.floor(v.G*255), b = math.floor(v.B*255)}
    elseif typeof(v) == "EnumItem" then
        return {_t = "EnumItem", name = v.Name}
    end
    return v
end
local function deserializeValue(v)
    if type(v) == "table" and v._t == "Color3" then
        return Color3.fromRGB(v.r, v.g, v.b)
    elseif type(v) == "table" and v._t == "EnumItem" then
        local ok, e = pcall(function() return Enum.KeyCode[v.name] end)
        if ok then return e end
    end
    return v
end

function EniLib:GetConfigPath(window, name)
    name = name or "default"
    return "EniLibConfigs/" .. (window._configFolder or "default") .. "/" .. name .. ".json"
end

function EniLib:SaveConfig(window, name)
    if not hasFiles then return false, "executor has no file I/O" end
    name = name or "default"
    ensureFolder("EniLibConfigs")
    ensureFolder("EniLibConfigs/" .. (window._configFolder or "default"))
    local data = {}
    for flag, h in pairs(EniLib.Flags) do
        local v = h.CurrentValue or h.CurrentOption or h.CurrentKeybind or h.CurrentColor
        if v ~= nil then data[flag] = serializeValue(v) end
    end
    local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then return false, json end
    local path = self:GetConfigPath(window, name)
    writefile(path, json)
    return true, path
end

function EniLib:LoadConfig(window, name)
    if not hasFiles then return false, "executor has no file I/O" end
    name = name or "default"
    local path = self:GetConfigPath(window, name)
    if not isfile(path) then return false, "config '"..name.."' not found" end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, readfile(path))
    if not ok then return false, data end
    for flag, v in pairs(data) do
        local h = EniLib.Flags[flag]
        if h and h.Set then pcall(h.Set, h, deserializeValue(v)) end
    end
    return true
end

function EniLib:HasFileIO() return hasFiles end

