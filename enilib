        function Tab:CreateKeybind(o)
            local key = o.CurrentKeybind or Enum.KeyCode.E
            local listening = false
            local row = mkRow(rowH)
            local label = new("TextLabel", {
                Position = UDim2.new(0, 14, 0, 0),
                Size = UDim2.new(1, -130, 1, 0),
                BackgroundTransparency = 1,
                Text = o.Name or "Keybind",
                TextColor3 = theme.Text,
                Font = Enum.Font.Gotham, TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 7, Parent = row,
            })
            local kbtn = new("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0.5, 0),
                Size = UDim2.fromOffset(110, isMobile and 28 or 26),
                BackgroundColor3 = theme.Elevated,
                BackgroundTransparency = 0.1,
                BorderSizePixel = 0,
                Text = key.Name, TextColor3 = theme.Text,
                Font = Enum.Font.Gotham, TextSize = 12,
                AutoButtonColor = false,
                ZIndex = 8, Parent = row,
            })
            corner(kbtn, 6); stroke(kbtn, theme.Border, 1, 0.5)
            kbtn.MouseButton1Click:Connect(function()
                listening = true; kbtn.Text = "..."
                tw(kbtn, SPEED(0.15), {BackgroundColor3 = theme.AccentDark})
            end)
            UserInputService.InputBegan:Connect(function(i, gp)
                if gp then return end
                if listening and i.UserInputType == Enum.UserInputType.Keyboard then
                    key = i.KeyCode; kbtn.Text = key.Name; listening = false
                    tw(kbtn, SPEED(0.15), {BackgroundColor3 = theme.Elevated})
                    if o.Callback then pcall(o.Callback, key) end
                    autosave()
                elseif not listening and i.KeyCode == key then
                    if o.Callback then pcall(o.Callback, key) end
                end
            end)
            local h = {CurrentKeybind = key}
            function h:Set(k)
                key = (typeof(k) == "EnumItem") and k or Enum.KeyCode[k] or key
                kbtn.Text = key.Name; self.CurrentKeybind = key
            end
            if o.Flag then EniLib.Flags[o.Flag] = h end
            table.insert(repainters, function(t)
                tw(label, 0.3, {TextColor3 = t.Text})
                tw(kbtn, 0.3, {BackgroundColor3 = t.Elevated, TextColor3 = t.Text})
            end)
            return h
        end

        function Tab:CreateColorPicker(o)
            local color = o.Color or theme.Accent
            local h_, s_, v_ = Color3.toHSV(color)
            local row = mkRow(rowH)
            row.ClipsDescendants = true
            local label = new("TextLabel", {
                Position = UDim2.new(0, 14, 0, 0),
                Size = UDim2.new(1, -60, 0, rowH),
                BackgroundTransparency = 1,
                Text = o.Name or "Color",
                TextColor3 = theme.Text,
                Font = Enum.Font.Gotham, TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 7, Parent = row,
            })
            local swatch = new("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0, rowH / 2),
                Size = UDim2.fromOffset(34, 22),
                BackgroundColor3 = color,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                Text = "", AutoButtonColor = false,
                ZIndex = 8, Parent = row,
            })
            corner(swatch, 6); stroke(swatch, theme.Border, 1, 0.3)
            attachShimmer(swatch, {Duration = 2.0, Gap = 2.6, Peak = 0.2, Band = 0.16, Rotation = 18})

            local panel = new("Frame", {
                Position = UDim2.new(0, 14, 0, rowH + 8),
                Size = UDim2.new(1, -28, 0, 130),
                BackgroundTransparency = 1,
                ZIndex = 7, Parent = row,
            })
            local sv = new("Frame", {
                Size = UDim2.new(0, 130, 1, -16),
                BackgroundColor3 = Color3.fromHSV(h_, 1, 1),
                BorderSizePixel = 0, ZIndex = 8, Parent = panel,
            })
            corner(sv, 6); stroke(sv, theme.Border, 1, 0.3)
            new("UIGradient", {
                Color = ColorSequence.new(Color3.fromRGB(255, 255, 255), Color3.fromRGB(255, 255, 255)),
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1),
                }, Parent = sv,
            })
            local svValueOverlay = new("Frame", {
                Size = UDim2.fromScale(1, 1),
                BackgroundColor3 = Color3.fromRGB(0, 0, 0),
                BorderSizePixel = 0, ZIndex = 9, Parent = sv,
            })
            corner(svValueOverlay, 6)
            new("UIGradient", {
                Color = ColorSequence.new(Color3.fromRGB(0, 0, 0)),
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                }, Rotation = 90, Parent = svValueOverlay,
            })
            local svKnob = new("Frame", {
                AnchorPoint = Vector2.new(0.5, 0.5),
                Size = UDim2.fromOffset(10, 10),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0, ZIndex = 11, Parent = sv,
            })
            corner(svKnob, 5); stroke(svKnob, Color3.fromRGB(0, 0, 0), 1, 0.3)

            local hue = new("Frame", {
                Position = UDim2.new(0, 138, 0, 0),
                Size = UDim2.new(0, 16, 1, -16),
                BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                ZIndex = 8, Parent = panel,
            })
            corner(hue, 6); stroke(hue, theme.Border, 1, 0.3)
            new("UIGradient", {
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
                }, Rotation = 90, Parent = hue,
            })
            local hueKnob = new("Frame", {
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0.5, 0, h_, 0),
                Size = UDim2.new(1, 6, 0, 3),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0, ZIndex = 11, Parent = hue,
            })
            corner(hueKnob, 1)

            local rgbLabel = new("TextLabel", {
                Position = UDim2.new(0, 164, 0, 0),
                Size = UDim2.new(1, -164, 0, 18),
                BackgroundTransparency = 1,
                Text = "", TextColor3 = theme.Text,
                Font = Enum.Font.Gotham, TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 8, Parent = panel,
            })
            local hexLabel = new("TextLabel", {
                Position = UDim2.new(0, 164, 0, 22),
                Size = UDim2.new(1, -164, 0, 18),
                BackgroundTransparency = 1,
                Text = "", TextColor3 = theme.SubText,
                Font = Enum.Font.GothamBold, TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 8, Parent = panel,
            })

            local handle = {CurrentColor = color}
            local function apply()
                local c = Color3.fromHSV(h_, s_, v_)
                handle.CurrentColor = c
                swatch.BackgroundColor3 = c
                sv.BackgroundColor3 = Color3.fromHSV(h_, 1, 1)
                svKnob.Position = UDim2.new(s_, 0, 1 - v_, 0)
                hueKnob.Position = UDim2.new(0.5, 0, h_, 0)
                local r, g, b = math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255)
                rgbLabel.Text = ("RGB  %d, %d, %d"):format(r, g, b)
                hexLabel.Text = ("#%02X%02X%02X"):format(r, g, b)
                if o.Callback then pcall(o.Callback, c) end
                autosave()
            end
            apply()

            local open = false
            swatch.MouseButton1Click:Connect(function()
                open = not open
                if open then tw(row, SPEED(0.3), {Size = UDim2.new(1, 0, 0, rowH + 146)}, Enum.EasingStyle.Back)
                else tw(row, SPEED(0.25), {Size = UDim2.new(1, 0, 0, rowH)}) end
            end)
            local dragSV, dragHue
            sv.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragSV = true end
            end)
            hue.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragHue = true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragSV, dragHue = false, false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if not (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then return end
                if dragSV then
                    s_ = math.clamp((i.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
                    v_ = 1 - math.clamp((i.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
                    apply()
                end
                if dragHue then
                    h_ = math.clamp((i.Position.Y - hue.AbsolutePosition.Y) / hue.AbsoluteSize.Y, 0, 1)
                    apply()
                end
            end)
            function handle:Set(c)
                if typeof(c) == "Color3" then h_, s_, v_ = Color3.toHSV(c); apply() end
            end
            if o.Flag then EniLib.Flags[o.Flag] = handle end
            table.insert(repainters, function(t)
                tw(label,   0.3, {TextColor3 = t.Text})
                tw(rgbLabel,0.3, {TextColor3 = t.Text})
                tw(hexLabel,0.3, {TextColor3 = t.SubText})
            end)
            return handle
        end

        return Tab
    end

