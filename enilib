            local valueBtn = new("TextButton", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -14, 0, 8), Size = UDim2.new(0, 140, 0, 22),
                BackgroundColor3 = theme.Elevated, BackgroundTransparency = 0.2,
                BorderSizePixel = 0, Text = "  " .. tostring(current),
