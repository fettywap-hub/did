function EniLib:Notify(opts)
    opts = opts or {}
    local theme = self._theme or Themes.Rose
    local accentColor = ({info=theme.Accent, success=theme.Success,
                          warning=theme.Warning, error=theme.Danger})[opts.Type or "info"]

    local card = new("Frame", {
        Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = theme.Surface, BackgroundTransparency = 0.15,
        BorderSizePixel = 0, Parent = NotifContainer,
    })
    corner(card, 12); stroke(card, theme.Border, 1, 0.3)
    -- glass gloss
    local gloss = new("Frame", {
        Size = UDim2.new(1, 0, 0.6, 0), BackgroundTransparency = 1,
        BorderSizePixel = 0, Parent = card,
    })
    corner(gloss, 12)
    new("UIGradient", {
        Color = ColorSequence.new(Color3.fromRGB(255,255,255)),
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, 0.88),
            NumberSequenceKeypoint.new(1, 1),
        }, Rotation = 90, Parent = gloss,
    })
    gloss.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    gloss.BackgroundTransparency = 0.88

    local accent = new("Frame", {
        Position = UDim2.new(0, 10, 0, 10), Size = UDim2.new(0, 3, 1, -20),
        BackgroundColor3 = accentColor, BorderSizePixel = 0, Parent = card,
    })
    corner(accent, 2)

    local title = new("TextLabel", {
        Position = UDim2.new(0, 22, 0, 10), Size = UDim2.new(1, -32, 0, 18),
        BackgroundTransparency = 1, Text = opts.Title or "Notification",
        TextColor3 = theme.Text, Font = Enum.Font.GothamBold, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left, TextTransparency = 1, Parent = card,
    })
    local body = new("TextLabel", {
        Position = UDim2.new(0, 22, 0, 30), Size = UDim2.new(1, -32, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1,
        Text = opts.Content or "", TextColor3 = theme.SubText,
        Font = Enum.Font.Gotham, TextSize = 12, TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top,
        TextTransparency = 1, Parent = card,
    })
    padding(card, 0, 0, 14, 0)

    card.Position = UDim2.new(1, 100, 0, 0)
    tw(card, 0.35, {Position = UDim2.new(0, 0, 0, 0)}, Enum.EasingStyle.Back)
    tw(title, 0.3, {TextTransparency = 0})
    tw(body, 0.3, {TextTransparency = 0})

    task.delay(0.2, function()
        local flash = Color3.fromRGB(255,255,255):Lerp(accentColor, 0.3)
        tw(accent, 0.15, {BackgroundColor3 = flash})
        task.wait(0.15)
        tw(accent, 0.4, {BackgroundColor3 = accentColor})
    end)

    task.spawn(function()
        task.wait(opts.Duration or 4)
        tw(card, 0.3, {BackgroundTransparency = 1})
        tw(gloss, 0.3, {BackgroundTransparency = 1})
        tw(title, 0.3, {TextTransparency = 1})
        tw(body, 0.3, {TextTransparency = 1})
        tw(accent, 0.3, {BackgroundTransparency = 1})
        task.wait(0.35); card:Destroy()
    end)
end

