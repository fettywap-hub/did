            Size = UDim2.new(1, iconId and -36 or -16, 1, 0),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = theme.SubText,
            Font = Enum.Font.Gotham,
            TextSize = isMobile and 14 or 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 8, Parent = tabBtn,
        })
        local tabIcon
        if iconId then
            tabIcon = new("ImageLabel", {
                Position = UDim2.new(0, 8, 0.5, -8),
                Size = UDim2.fromOffset(16, 16),
                BackgroundTransparency = 1,
                Image = "rbxassetid://" .. tostring(iconId),
                ImageColor3 = theme.SubText,
                ZIndex = 8, Parent = tabBtn,
            })
        end

        local TabFrame = new("ScrollingFrame", {
            Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.AccentDark,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false,
            ZIndex = 4, Parent = Content,
        }, {new("UIListLayout", {Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder})})
        padding(TabFrame, 14, 14, 14, 14)

        local tabRecord = {btn = tabBtn, frame = TabFrame, label = tabLabel, icon = tabIcon, selected = false}
        local function select()
            for _, t in ipairs(WindowObj._tabs) do
                if t.frame.Visible and t.frame ~= TabFrame then
                    tw(t.frame, SPEED(0.18), {Position = UDim2.fromScale(-0.04, 0)})
                    task.delay(SPEED(0.18), function() t.frame.Visible = false end)
                end
                tw(t.label, SPEED(0.15), {TextColor3 = theme.SubText})
                if t.icon then tw(t.icon, SPEED(0.15), {ImageColor3 = theme.SubText}) end
                tw(t.btn, SPEED(0.15), {BackgroundTransparency = 1})
                t.selected = false
            end
            TabFrame.Position = UDim2.fromScale(0.04, 0)
            TabFrame.Visible = true
            tw(TabFrame, SPEED(0.25), {Position = UDim2.fromScale(0, 0)})
            tw(tabBtn,   SPEED(0.18), {BackgroundTransparency = 0.4, BackgroundColor3 = theme.Elevated})
            tw(tabLabel, SPEED(0.18), {TextColor3 = theme.Text})
            if tabIcon then tw(tabIcon, SPEED(0.18), {ImageColor3 = theme.Accent}) end
            local absPos = tabBtn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y
            tw(Indicator, SPEED(0.3), {
                Position = UDim2.new(0, 6, 0, absPos + 3),
                BackgroundTransparency = 0,
            }, Enum.EasingStyle.Back)
            tw(indicatorGlow, SPEED(0.3), {Transparency = 0.5})
            task.delay(SPEED(0.3), function() tw(indicatorGlow, 0.4, {Transparency = 1}) end)
            tabRecord.selected = true
        end

        tabBtn.MouseButton1Click:Connect(select)
        tabBtn.MouseEnter:Connect(function()
            if not tabRecord.selected then tw(tabLabel, SPEED(0.12), {TextColor3 = theme.Text}) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if not tabRecord.selected then tw(tabLabel, SPEED(0.12), {TextColor3 = theme.SubText}) end
        end)

        table.insert(WindowObj._tabs, tabRecord)
        if #WindowObj._tabs == 1 then task.defer(select) end

        table.insert(repainters, function(t)
            tw(tabBtn, 0.3, {BackgroundColor3 = t.Elevated})
            tw(tabLabel, 0.3, {TextColor3 = tabRecord.selected and t.Text or t.SubText})
            if tabIcon then tw(tabIcon, 0.3, {ImageColor3 = tabRecord.selected and t.Accent or t.SubText}) end
            tw(TabFrame, 0.3, {ScrollBarImageColor3 = t.AccentDark})
        end)

